<Window x:Class="ToastDesigner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ToastDesigner.Controls"
        Title="Toast Designer"
        MinWidth="1060" MinHeight="700"
        Width="1160" Height="780"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="530"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── LEFT: Editor panel ── -->
        <Border Grid.Column="0"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Footer buttons — pinned to bottom -->
                <Border DockPanel.Dock="Bottom"
                        Background="{StaticResource BrushSurface}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,1,0,0"
                        Padding="14,10">
                    <WrapPanel Orientation="Horizontal">
                        <Button x:Name="ExportBtn"
                                Style="{StaticResource PrimaryButton}"
                                Content="Copy Masher JSON"
                                Click="Export_Click"
                                Margin="0,0,8,0"/>
                        <Button x:Name="SaveBtn"
                                Style="{StaticResource GhostButton}"
                                Content="Save Theme"
                                Click="Save_Click"
                                Margin="0,0,8,0"/>
                        <Button x:Name="LoadBtn"
                                Style="{StaticResource GhostButton}"
                                Content="Load Theme"
                                Click="Load_Click"
                                Margin="0,0,8,0"/>
                        <Button x:Name="ResetBtn"
                                Style="{StaticResource GhostButton}"
                                Content="Reset"
                                Click="Reset_Click"/>
                    </WrapPanel>
                </Border>

                <!-- Scrollable editor -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,12,16,12">

                        <!-- Title -->
                        <TextBlock Text="Toast Designer"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource BrushAccent}"
                                   Margin="0,0,0,16"/>

                        <!-- ══ BACKGROUND ══ -->
                        <Expander Header="Background">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Effect -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Effect" VerticalAlignment="Center" Foreground="{StaticResource BrushTextMuted}"/>
                                <ComboBox x:Name="BgEffectCombo" Grid.Row="0" Grid.Column="1"
                                          Height="30"
                                          SelectionChanged="BgEffectCombo_SelectionChanged">
                                    <ComboBoxItem>Gradient</ComboBoxItem>
                                    <ComboBoxItem>Solid</ComboBoxItem>
                                    <ComboBoxItem>Radial Glow</ComboBoxItem>
                                    <ComboBoxItem>Grain</ComboBoxItem>
                                    <ComboBoxItem>Image</ComboBoxItem>
                                </ComboBox>

                                <!-- Color 1 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Color 1" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <controls:ColorPickerBox x:Name="BgColor1Picker" Grid.Row="1" Grid.Column="1"
                                                         HexValue="#1c2748" Height="30" Margin="0,8,0,0"/>

                                <!-- Color 2 -->
                                <TextBlock x:Name="BgColor2Label" Grid.Row="2" Grid.Column="0" Text="Color 2" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <controls:ColorPickerBox x:Name="BgColor2Picker" Grid.Row="2" Grid.Column="1"
                                                         HexValue="#111832" Height="30" Margin="0,8,0,0"/>

                                <!-- Image path (hidden unless Effect = Image) -->
                                <TextBlock x:Name="BgImageLabel" Grid.Row="3" Grid.Column="0" Text="Image" VerticalAlignment="Center" Margin="0,8,0,0"
                                           Foreground="{StaticResource BrushTextMuted}" Visibility="Collapsed"/>
                                <Grid x:Name="BgImageRow" Grid.Row="3" Grid.Column="1"
                                      Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="BgImagePathBox" Grid.Column="0"
                                             Height="30" IsReadOnly="True"
                                             FontSize="11" Foreground="{StaticResource BrushTextMuted}"
                                             ToolTip="Background image path"/>
                                    <Button Grid.Column="1" Content="Browse"
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,4" Margin="6,0,0,0"
                                            Click="BrowseBgImage_Click"/>
                                </Grid>

                                <!-- Opacity -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Opacity" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <DockPanel Grid.Row="4" Grid.Column="1" Margin="0,10,0,0">
                                    <TextBlock x:Name="BgOpacityValue" DockPanel.Dock="Right"
                                               Text="1.00" Width="34" TextAlignment="Right"
                                               VerticalAlignment="Center" FontSize="11"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                    <Slider x:Name="BgOpacitySlider"
                                            Minimum="0" Maximum="1" Value="1"
                                            SmallChange="0.01" LargeChange="0.05"
                                            ValueChanged="Slider_ValueChanged"/>
                                </DockPanel>

                                <!-- Shimmer -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Shimmer" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <ComboBox x:Name="ShimmerCombo" Grid.Row="5" Grid.Column="1"
                                          Height="30" Margin="0,8,0,0"
                                          SelectionChanged="Combo_SelectionChanged">
                                    <ComboBoxItem>Diagonal</ComboBoxItem>
                                    <ComboBoxItem>Horizontal</ComboBoxItem>
                                    <ComboBoxItem>Pulse</ComboBoxItem>
                                    <ComboBoxItem>Static Gloss</ComboBoxItem>
                                    <ComboBoxItem>Slide-Through</ComboBoxItem>
                                    <ComboBoxItem>Spotlight</ComboBoxItem>
                                    <ComboBoxItem>Breathing</ComboBoxItem>
                                    <ComboBoxItem>None</ComboBoxItem>
                                </ComboBox>

                            </Grid>
                        </Expander>

                        <!-- ══ BORDER ══ -->
                        <Expander Header="Border">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Animation -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Animation" VerticalAlignment="Center" Foreground="{StaticResource BrushTextMuted}"/>
                                <ComboBox x:Name="BorderAnimCombo" Grid.Row="0" Grid.Column="1"
                                          Height="30"
                                          SelectionChanged="Combo_SelectionChanged">
                                    <ComboBoxItem>Bottom Bar Drain</ComboBoxItem>
                                    <ComboBoxItem>Fill from Centre</ComboBoxItem>
                                    <ComboBoxItem>Full Border Trace</ComboBoxItem>
                                    <ComboBoxItem>Orbiting Spark</ComboBoxItem>
                                    <ComboBoxItem>Bouncing Edge</ComboBoxItem>
                                    <ComboBoxItem>None</ComboBoxItem>
                                </ComboBox>

                                <!-- Border Color -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Color" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <controls:ColorPickerBox x:Name="BorderColorPicker" Grid.Row="1" Grid.Column="1"
                                                         HexValue="#1DB954" Height="30" Margin="0,8,0,0"/>

                                <!-- Thickness -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Thickness" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,10,0,0">
                                    <TextBlock x:Name="BorderThicknessValue" DockPanel.Dock="Right"
                                               Text="1.5" Width="34" TextAlignment="Right"
                                               VerticalAlignment="Center" FontSize="11"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                    <Slider x:Name="BorderThicknessSlider"
                                            Minimum="0" Maximum="8" Value="1.5"
                                            SmallChange="0.5" LargeChange="1"
                                            ValueChanged="Slider_ValueChanged"/>
                                </DockPanel>

                                <!-- Corner Radius -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Radius" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,10,0,0">
                                    <TextBlock x:Name="CornerRadiusValue" DockPanel.Dock="Right"
                                               Text="10" Width="34" TextAlignment="Right"
                                               VerticalAlignment="Center" FontSize="11"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                    <Slider x:Name="CornerRadiusSlider"
                                            Minimum="0" Maximum="28" Value="10"
                                            SmallChange="1" LargeChange="4"
                                            ValueChanged="Slider_ValueChanged"/>
                                </DockPanel>

                                <!-- Border Opacity -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Opacity" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <DockPanel Grid.Row="4" Grid.Column="1" Margin="0,10,0,0">
                                    <TextBlock x:Name="BorderOpacityValue" DockPanel.Dock="Right"
                                               Text="1.00" Width="34" TextAlignment="Right"
                                               VerticalAlignment="Center" FontSize="11"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                    <Slider x:Name="BorderOpacitySlider"
                                            Minimum="0" Maximum="1" Value="1"
                                            SmallChange="0.01" LargeChange="0.05"
                                            ValueChanged="Slider_ValueChanged"/>
                                </DockPanel>

                                <!-- Glow toggle -->
                                <CheckBox x:Name="GlowCheck" Grid.Row="5" Grid.ColumnSpan="2"
                                          Content="Enable glow / shadow" IsChecked="True"
                                          Margin="0,12,0,0"
                                          Checked="GlowCheck_Changed"
                                          Unchecked="GlowCheck_Changed"/>

                                <!-- Glow Color -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Glow Color" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <controls:ColorPickerBox x:Name="GlowColorPicker" Grid.Row="6" Grid.Column="1"
                                                         HexValue="#1DB954" Height="30" Margin="0,8,0,0"/>

                                <!-- Glow Intensity -->
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Intensity" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <DockPanel Grid.Row="7" Grid.Column="1" Margin="0,10,0,0">
                                    <TextBlock x:Name="GlowIntensityValue" DockPanel.Dock="Right"
                                               Text="16" Width="34" TextAlignment="Right"
                                               VerticalAlignment="Center" FontSize="11"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                    <Slider x:Name="GlowIntensitySlider"
                                            Minimum="0" Maximum="40" Value="16"
                                            SmallChange="1" LargeChange="4"
                                            ValueChanged="Slider_ValueChanged"/>
                                </DockPanel>

                                <!-- Outer shadow colour (separate from border colour) -->
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Shadow" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <controls:ColorPickerBox x:Name="ShadowColorPicker" Grid.Row="8" Grid.Column="1"
                                                         HexValue="#1DB954" Height="30" Margin="0,8,0,0"/>

                            </Grid>
                        </Expander>

                        <!-- ══ TEXT ══ -->
                        <Expander Header="Text">
                            <StackPanel>

                                <!-- Track -->
                                <TextBlock Text="Track Name"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushAccent}"
                                           Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Color" VerticalAlignment="Center" Foreground="{StaticResource BrushTextMuted}"/>
                                    <controls:ColorPickerBox x:Name="TrackColorPicker" Grid.Row="0" Grid.Column="1"
                                                             HexValue="#FFFFFF" Height="30"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Font Size" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
                                        <TextBlock x:Name="TrackSizeValue" DockPanel.Dock="Right"
                                                   Text="14" Width="34" TextAlignment="Right"
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                        <Slider x:Name="TrackSizeSlider"
                                                Minimum="8" Maximum="24" Value="14"
                                                SmallChange="0.5" LargeChange="2"
                                                ValueChanged="Slider_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Weight" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <ComboBox x:Name="TrackWeightCombo" Grid.Row="2" Grid.Column="1"
                                              Height="30" Margin="0,8,0,0"
                                              SelectionChanged="Combo_SelectionChanged">
                                        <ComboBoxItem>Thin</ComboBoxItem>
                                        <ComboBoxItem>Light</ComboBoxItem>
                                        <ComboBoxItem>Regular</ComboBoxItem>
                                        <ComboBoxItem IsSelected="True">Normal</ComboBoxItem>
                                        <ComboBoxItem>Medium</ComboBoxItem>
                                        <ComboBoxItem>SemiBold</ComboBoxItem>
                                        <ComboBoxItem>Bold</ComboBoxItem>
                                        <ComboBoxItem>ExtraBold</ComboBoxItem>
                                        <ComboBoxItem>Black</ComboBoxItem>
                                    </ComboBox>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Prefix / Suffix" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <Grid Grid.Row="3" Grid.Column="1" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TrackPrefixBox" Grid.Column="0" Height="30"
                                                 FontSize="11" ToolTip="Prefix"
                                                 TextChanged="TextBox_Changed"/>
                                        <TextBox x:Name="TrackSuffixBox" Grid.Column="2" Height="30"
                                                 FontSize="11" ToolTip="Suffix"
                                                 TextChanged="TextBox_Changed"/>
                                    </Grid>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Opacity" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <DockPanel Grid.Row="4" Grid.Column="1" Margin="0,10,0,0">
                                        <TextBlock x:Name="TrackOpacityValue" DockPanel.Dock="Right"
                                                   Text="1.00" Width="34" TextAlignment="Right"
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                        <Slider x:Name="TrackOpacitySlider"
                                                Minimum="0" Maximum="1" Value="1"
                                                SmallChange="0.01" LargeChange="0.05"
                                                ValueChanged="Slider_ValueChanged"/>
                                    </DockPanel>
                                </Grid>

                                <Separator/>

                                <!-- Artist -->
                                <TextBlock Text="Artist"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushAccent}"
                                           Margin="0,6,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Color" VerticalAlignment="Center" Foreground="{StaticResource BrushTextMuted}"/>
                                    <controls:ColorPickerBox x:Name="ArtistColorPicker" Grid.Row="0" Grid.Column="1"
                                                             HexValue="#1DB954" Height="30"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Font Size" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
                                        <TextBlock x:Name="ArtistSizeValue" DockPanel.Dock="Right"
                                                   Text="12.5" Width="34" TextAlignment="Right"
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                        <Slider x:Name="ArtistSizeSlider"
                                                Minimum="8" Maximum="24" Value="12.5"
                                                SmallChange="0.5" LargeChange="2"
                                                ValueChanged="Slider_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Weight" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <ComboBox x:Name="ArtistWeightCombo" Grid.Row="2" Grid.Column="1"
                                              Height="30" Margin="0,8,0,0"
                                              SelectionChanged="Combo_SelectionChanged">
                                        <ComboBoxItem>Thin</ComboBoxItem>
                                        <ComboBoxItem>Light</ComboBoxItem>
                                        <ComboBoxItem>Regular</ComboBoxItem>
                                        <ComboBoxItem>Normal</ComboBoxItem>
                                        <ComboBoxItem>Medium</ComboBoxItem>
                                        <ComboBoxItem>SemiBold</ComboBoxItem>
                                        <ComboBoxItem IsSelected="True">Bold</ComboBoxItem>
                                        <ComboBoxItem>ExtraBold</ComboBoxItem>
                                        <ComboBoxItem>Black</ComboBoxItem>
                                    </ComboBox>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Prefix / Suffix" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <Grid Grid.Row="3" Grid.Column="1" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ArtistPrefixBox" Grid.Column="0" Height="30"
                                                 FontSize="11" ToolTip="Prefix"
                                                 TextChanged="TextBox_Changed"/>
                                        <TextBox x:Name="ArtistSuffixBox" Grid.Column="2" Height="30"
                                                 FontSize="11" ToolTip="Suffix"
                                                 TextChanged="TextBox_Changed"/>
                                    </Grid>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Opacity" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <DockPanel Grid.Row="4" Grid.Column="1" Margin="0,10,0,0">
                                        <TextBlock x:Name="ArtistOpacityValue" DockPanel.Dock="Right"
                                                   Text="1.00" Width="34" TextAlignment="Right"
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                        <Slider x:Name="ArtistOpacitySlider"
                                                Minimum="0" Maximum="1" Value="1"
                                                SmallChange="0.01" LargeChange="0.05"
                                                ValueChanged="Slider_ValueChanged"/>
                                    </DockPanel>
                                </Grid>

                                <Separator/>

                                <!-- Album -->
                                <TextBlock Text="Album"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushAccent}"
                                           Margin="0,6,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Color" VerticalAlignment="Center" Foreground="{StaticResource BrushTextMuted}"/>
                                    <controls:ColorPickerBox x:Name="AlbumColorPicker" Grid.Row="0" Grid.Column="1"
                                                             HexValue="#A0A0B0" Height="30"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Font Size" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,10,0,0">
                                        <TextBlock x:Name="AlbumSizeValue" DockPanel.Dock="Right"
                                                   Text="11.5" Width="34" TextAlignment="Right"
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                        <Slider x:Name="AlbumSizeSlider"
                                                Minimum="8" Maximum="24" Value="11.5"
                                                SmallChange="0.5" LargeChange="2"
                                                ValueChanged="Slider_ValueChanged"/>
                                    </DockPanel>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Weight" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <ComboBox x:Name="AlbumWeightCombo" Grid.Row="2" Grid.Column="1"
                                              Height="30" Margin="0,8,0,0"
                                              SelectionChanged="Combo_SelectionChanged">
                                        <ComboBoxItem>Thin</ComboBoxItem>
                                        <ComboBoxItem>Light</ComboBoxItem>
                                        <ComboBoxItem IsSelected="True">Regular</ComboBoxItem>
                                        <ComboBoxItem>Normal</ComboBoxItem>
                                        <ComboBoxItem>Medium</ComboBoxItem>
                                        <ComboBoxItem>SemiBold</ComboBoxItem>
                                        <ComboBoxItem>Bold</ComboBoxItem>
                                        <ComboBoxItem>ExtraBold</ComboBoxItem>
                                        <ComboBoxItem>Black</ComboBoxItem>
                                    </ComboBox>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Prefix / Suffix" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <Grid Grid.Row="3" Grid.Column="1" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="AlbumPrefixBox" Grid.Column="0" Height="30"
                                                 FontSize="11" ToolTip="Prefix"
                                                 TextChanged="TextBox_Changed"/>
                                        <TextBox x:Name="AlbumSuffixBox" Grid.Column="2" Height="30"
                                                 FontSize="11" ToolTip="Suffix"
                                                 TextChanged="TextBox_Changed"/>
                                    </Grid>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Opacity" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                    <DockPanel Grid.Row="4" Grid.Column="1" Margin="0,10,0,0">
                                        <TextBlock x:Name="AlbumOpacityValue" DockPanel.Dock="Right"
                                                   Text="1.00" Width="34" TextAlignment="Right"
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Foreground="{StaticResource BrushTextMuted}"/>
                                        <Slider x:Name="AlbumOpacitySlider"
                                                Minimum="0" Maximum="1" Value="1"
                                                SmallChange="0.01" LargeChange="0.05"
                                                ValueChanged="Slider_ValueChanged"/>
                                    </DockPanel>
                                </Grid>

                            </StackPanel>
                        </Expander>

                        <!-- ══ SAMPLE DATA ══ -->
                        <Expander Header="Sample Data">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Track" VerticalAlignment="Center" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBox x:Name="SampleTrackBox" Grid.Row="0" Grid.Column="1"
                                         Text="Lose Yourself" Height="30"
                                         TextChanged="SampleData_Changed"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Artist" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBox x:Name="SampleArtistBox" Grid.Row="1" Grid.Column="1"
                                         Text="Eminem" Height="30" Margin="0,8,0,0"
                                         TextChanged="SampleData_Changed"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Album" VerticalAlignment="Center" Margin="0,8,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBox x:Name="SampleAlbumBox" Grid.Row="2" Grid.Column="1"
                                         Text="8 Mile" Height="30" Margin="0,8,0,0"
                                         TextChanged="SampleData_Changed"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Album Art" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{StaticResource BrushTextMuted}"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                                    <Border Width="48" Height="48"
                                            Background="{StaticResource BrushSurface2}"
                                            CornerRadius="4" Margin="0,0,8,0"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="1">
                                        <Image x:Name="SampleArtThumb"
                                               Stretch="UniformToFill"/>
                                    </Border>
                                    <Button Content="Browse Art"
                                            Style="{StaticResource GhostButton}"
                                            Padding="10,6"
                                            VerticalAlignment="Center"
                                            Click="BrowseArt_Click"/>
                                    <Button Content="Clear"
                                            Style="{StaticResource GhostButton}"
                                            Padding="10,6"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            Click="ClearArt_Click"/>
                                </StackPanel>
                            </Grid>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── RIGHT: Preview panel ── -->
        <Grid Grid.Column="1">
            <!-- Dot-grid background — makes transparency/opacity visible -->
            <Border>
                <Border.Background>
                    <DrawingBrush TileMode="Tile"
                                  Viewport="0,0,20,20"
                                  ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="#22444466">
                                <GeometryDrawing.Geometry>
                                    <EllipseGeometry Center="10,10" RadiusX="1.5" RadiusY="1.5"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Border.Background>
            </Border>

            <!-- Preview content -->
            <DockPanel>
                <!-- Top bar: label + play/pause -->
                <Border DockPanel.Dock="Top"
                        Background="#CC16213e"
                        Padding="12,8">
                    <DockPanel>
                        <Button x:Name="PlayPauseBtn"
                                DockPanel.Dock="Right"
                                Style="{StaticResource GhostButton}"
                                Content="⏸ Pause"
                                Padding="10,5"
                                Click="PlayPause_Click"/>
                        <TextBlock Text="LIVE PREVIEW"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Toast centred on dot-grid -->
                <Grid>
                    <controls:PreviewToastControl x:Name="Preview"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="32"/>
                </Grid>
            </DockPanel>
        </Grid>

    </Grid>
</Window>
