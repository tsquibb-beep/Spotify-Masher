<UserControl x:Class="ToastDesigner.Controls.PreviewToastControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

    <Border x:Name="ToastBorder"
            Background="Transparent"
            BorderThickness="1.5"
            CornerRadius="10"
            MinWidth="280"
            MaxWidth="520"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect x:Name="GlowEffect"
                              Color="#1DB954"
                              Opacity="0.45"
                              BlurRadius="16"
                              ShadowDepth="0"/>
        </Border.Effect>

        <Grid x:Name="ToastRoot">

            <!-- ── Background layer (can be hidden by layer toggle) ── -->
            <Border x:Name="BgLayer"/>

            <!-- Grain overlay (part of bg layer; hidden/shown with it) -->
            <Border x:Name="GrainOverlay"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"/>

            <!-- ── Content layer ── -->
            <Grid x:Name="ContentGrid" Margin="12,10,12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="AlbumArt"
                       Grid.Column="0"
                       Width="80" Height="80"
                       Stretch="UniformToFill"
                       VerticalAlignment="Center"
                       Visibility="Collapsed">
                    <Image.Clip>
                        <RectangleGeometry RadiusX="5" RadiusY="5" Rect="0,0,80,80"/>
                    </Image.Clip>
                </Image>

                <Grid x:Name="ArtGap" Grid.Column="1" Width="12" Visibility="Collapsed"/>

                <StackPanel x:Name="TrackPanel"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="0,2,0,2">

                    <TextBlock x:Name="TrackText"
                               FontFamily="{StaticResource FontLexend}"
                               FontSize="14"
                               FontWeight="Normal"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,3"/>

                    <TextBlock x:Name="ArtistText"
                               FontFamily="{StaticResource FontLexend}"
                               FontSize="12.5"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,3"/>

                    <TextBlock x:Name="AlbumText"
                               FontFamily="{StaticResource FontLexend}"
                               FontSize="11.5"
                               FontStyle="Italic"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>

            <!-- ── Shimmer canvas (shape-based, clipped to toast) ── -->
            <Canvas x:Name="ShimmerCanvas" IsHitTestVisible="False" ClipToBounds="True">
                <!-- ShimmerContainer is positioned and sized in code-behind -->
                <Grid x:Name="ShimmerContainer">
                    <Path x:Name="ShimmerShapePath"
                          Stretch="Fill"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="ShimmerRotTx"/>
                        </Path.RenderTransform>
                    </Path>
                </Grid>
            </Canvas>

            <!-- ── Border / action indicators (can be hidden by layer toggle) ── -->
            <Grid x:Name="BorderLayer">

                <!-- Bottom bar drain -->
                <Rectangle x:Name="CountdownBar"
                           Height="2"
                           VerticalAlignment="Bottom"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"
                           RenderTransformOrigin="0,0.5">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#661DB954" Offset="0"/>
                            <GradientStop Color="#FF1DB954" Offset="0.12"/>
                            <GradientStop Color="#FF1DB954" Offset="0.80"/>
                            <GradientStop Color="#FF4AE87A" Offset="0.91"/>
                            <GradientStop Color="#FFB8FFD8" Offset="0.97"/>
                            <GradientStop Color="#FFFFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.RenderTransform>
                        <ScaleTransform x:Name="CountdownScale"/>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <!-- Fill from centre -->
                <Rectangle x:Name="FillCentreRect"
                           Height="2"
                           VerticalAlignment="Bottom"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.RenderTransform>
                        <ScaleTransform x:Name="FillCentreScale" ScaleX="0"/>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <!-- Full border trace / orbiting spark -->
                <Rectangle x:Name="BorderTraceRect"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"
                           Fill="Transparent"
                           StrokeThickness="2"
                           RadiusX="9" RadiusY="9"/>

                <!-- Bouncing edge -->
                <Rectangle x:Name="TopEdgeRect"
                           Height="3"
                           VerticalAlignment="Top"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"/>

            </Grid>

        </Grid>
    </Border>
</UserControl>
