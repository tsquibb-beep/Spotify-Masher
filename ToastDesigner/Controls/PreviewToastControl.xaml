<UserControl x:Class="ToastDesigner.Controls.PreviewToastControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

    <Border x:Name="ToastBorder"
            BorderThickness="1.5"
            CornerRadius="10"
            MinWidth="280"
            MaxWidth="520"
            ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1c2748" Offset="0"/>
                <GradientStop Color="#111832" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect x:Name="GlowEffect"
                              Color="#1DB954"
                              Opacity="0.45"
                              BlurRadius="16"
                              ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <!-- Grain noise overlay -->
            <Border x:Name="GrainOverlay"
                    CornerRadius="9"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"/>

            <!-- Main content -->
            <Grid x:Name="ContentGrid" Margin="12,10,12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Album art thumbnail -->
                <Image x:Name="AlbumArt"
                       Grid.Column="0"
                       Width="80" Height="80"
                       Stretch="UniformToFill"
                       VerticalAlignment="Center"
                       Visibility="Collapsed">
                    <Image.Clip>
                        <RectangleGeometry RadiusX="5" RadiusY="5" Rect="0,0,80,80"/>
                    </Image.Clip>
                </Image>

                <!-- Art gap -->
                <Grid x:Name="ArtGap" Grid.Column="1" Width="12" Visibility="Collapsed"/>

                <!-- Rich track info (always shown in preview) -->
                <StackPanel x:Name="TrackPanel"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="0,2,0,2">

                    <TextBlock x:Name="TrackText"
                               FontFamily="{StaticResource FontLexend}"
                               FontSize="14"
                               FontWeight="Normal"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,3"/>

                    <TextBlock x:Name="ArtistText"
                               FontFamily="{StaticResource FontLexend}"
                               FontSize="12.5"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,3"/>

                    <TextBlock x:Name="AlbumText"
                               FontFamily="{StaticResource FontLexend}"
                               FontSize="11.5"
                               FontStyle="Italic"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>

            <!-- Shimmer sweep overlay -->
            <Border x:Name="SweepHighlight"
                    CornerRadius="9"
                    IsHitTestVisible="False"/>

            <!-- Bottom bar drain -->
            <Rectangle x:Name="CountdownBar"
                       Height="2"
                       VerticalAlignment="Bottom"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"
                       RenderTransformOrigin="0,0.5">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#661DB954" Offset="0"/>
                        <GradientStop Color="#FF1DB954" Offset="0.12"/>
                        <GradientStop Color="#FF1DB954" Offset="0.80"/>
                        <GradientStop Color="#FF4AE87A" Offset="0.91"/>
                        <GradientStop Color="#FFB8FFD8" Offset="0.97"/>
                        <GradientStop Color="#FFFFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.RenderTransform>
                    <ScaleTransform x:Name="CountdownScale"/>
                </Rectangle.RenderTransform>
            </Rectangle>

            <!-- Fill from centre -->
            <Rectangle x:Name="FillCentreRect"
                       Height="2"
                       VerticalAlignment="Bottom"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <ScaleTransform x:Name="FillCentreScale" ScaleX="0"/>
                </Rectangle.RenderTransform>
            </Rectangle>

            <!-- Full border trace / orbiting spark -->
            <Rectangle x:Name="BorderTraceRect"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"
                       Fill="Transparent"
                       StrokeThickness="2"
                       RadiusX="9" RadiusY="9"/>

            <!-- Bouncing edge -->
            <Rectangle x:Name="TopEdgeRect"
                       Height="3"
                       VerticalAlignment="Top"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"/>
        </Grid>
    </Border>
</UserControl>
