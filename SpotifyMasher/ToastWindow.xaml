<Window x:Class="SpotifyMasher.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        IsHitTestVisible="False"
        Focusable="False"
        ShowActivated="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="ToastBorder"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="8"
            MinWidth="180"
            MaxWidth="300"
            ClipToBounds="True"
            RenderTransformOrigin="0.5,0.5">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1c2748" Offset="0"/>
                <GradientStop Color="#111832" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <!-- Accent glow replaces the plain black shadow -->
        <Border.Effect>
            <DropShadowEffect Color="#1DB954" Opacity="0.45" BlurRadius="16" ShadowDepth="0"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform"/>
        </Border.RenderTransform>

        <Grid>
            <!-- Grain noise overlay — sits behind content; Background set in code-behind for Grain effect -->
            <Border x:Name="GrainOverlay"
                    CornerRadius="7"
                    IsHitTestVisible="False"
                    Visibility="Collapsed"/>

            <!-- Main content — padding applied via Margin so the bar/shimmer can reach the edges -->
            <Grid Margin="12,10,12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Album art — hidden for plain text toasts -->
                <Image x:Name="AlbumArt"
                       Grid.Column="0"
                       Width="80" Height="80"
                       Stretch="UniformToFill"
                       VerticalAlignment="Center"
                       Visibility="Collapsed">
                    <Image.Clip>
                        <RectangleGeometry RadiusX="5" RadiusY="5" Rect="0,0,80,80"/>
                    </Image.Clip>
                </Image>

                <!-- Spacer — hidden for plain text toasts -->
                <Grid x:Name="ArtGap" Grid.Column="1" Width="12" Visibility="Collapsed"/>

                <!-- Plain text (all non-rich toasts) -->
                <TextBlock x:Name="MessageText"
                           Grid.Column="2"
                           Foreground="{StaticResource BrushText}"
                           FontFamily="{StaticResource FontLexend}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           LineHeight="18"
                           VerticalAlignment="Center"/>

                <!-- Rich track info (Show Current Track) — hidden until populated -->
                <StackPanel x:Name="TrackPanel"
                            Grid.Column="2"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"
                            Margin="0,2,0,2">

                    <TextBlock x:Name="TrackText"
                               Foreground="{StaticResource BrushText}"
                               FontFamily="{StaticResource FontLexend}"
                               FontSize="14"
                               FontWeight="Normal"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,2"/>

                    <TextBlock x:Name="ArtistText"
                               Foreground="{StaticResource BrushAccent}"
                               FontFamily="{StaticResource FontLexend}"
                               FontSize="12.5"
                               FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,2"/>

                    <TextBlock x:Name="AlbumText"
                               Foreground="{StaticResource BrushTextMuted}"
                               FontFamily="{StaticResource FontLexend}"
                               FontSize="11.5"
                               FontStyle="Italic"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>

            <!-- Shimmer sweep — Border so its background is clipped to CornerRadius naturally.
                 Background (LinearGradientBrush) and animation set in code-behind. -->
            <Border x:Name="SweepHighlight" CornerRadius="7" IsHitTestVisible="False"/>

            <!-- Countdown bar — 2px, drains right-to-left over the toast duration -->
            <Rectangle x:Name="CountdownBar"
                       Height="2"
                       VerticalAlignment="Bottom"
                       IsHitTestVisible="False"
                       RenderTransformOrigin="0,0.5">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#661DB954" Offset="0"/>
                        <GradientStop Color="#FF1DB954" Offset="0.12"/>
                        <GradientStop Color="#FF1DB954" Offset="0.80"/>
                        <GradientStop Color="#FF4AE87A" Offset="0.91"/>
                        <GradientStop Color="#FFB8FFD8" Offset="0.97"/>
                        <GradientStop Color="#FFFFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.RenderTransform>
                    <ScaleTransform x:Name="CountdownScale"/>
                </Rectangle.RenderTransform>
            </Rectangle>

            <!-- Fill from centre — two halves grow outward; RenderTransformOrigin centred -->
            <Rectangle x:Name="FillCentreRect"
                       Height="2"
                       VerticalAlignment="Bottom"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <ScaleTransform x:Name="FillCentreScale" ScaleX="0"/>
                </Rectangle.RenderTransform>
            </Rectangle>

            <!-- Full border trace — StrokeDashOffset animated in code-behind -->
            <Rectangle x:Name="BorderTraceRect"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"
                       Fill="Transparent"
                       StrokeThickness="2"
                       RadiusX="7"
                       RadiusY="7"/>
        </Grid>
    </Border>
</Window>
