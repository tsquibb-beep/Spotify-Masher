<Window x:Class="SpotifyMasher.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        IsHitTestVisible="False"
        Focusable="False"
        ShowActivated="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="ToastBorder"
            Background="{StaticResource BrushSurface}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12,10"
            MinWidth="180"
            MaxWidth="300"
            RenderTransformOrigin="0.5,0.5">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="12" ShadowDepth="2"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform"/>
        </Border.RenderTransform>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Album art — hidden for plain text toasts -->
            <Image x:Name="AlbumArt"
                   Grid.Column="0"
                   Width="80" Height="80"
                   Stretch="UniformToFill"
                   VerticalAlignment="Center"
                   Visibility="Collapsed">
                <Image.Clip>
                    <RectangleGeometry RadiusX="5" RadiusY="5" Rect="0,0,80,80"/>
                </Image.Clip>
            </Image>

            <!-- Spacer — hidden for plain text toasts -->
            <Grid x:Name="ArtGap" Grid.Column="1" Width="12" Visibility="Collapsed"/>

            <!-- Plain text (all non-rich toasts) -->
            <TextBlock x:Name="MessageText"
                       Grid.Column="2"
                       Foreground="{StaticResource BrushText}"
                       FontFamily="Segoe UI Variable"
                       FontSize="13"
                       TextWrapping="Wrap"
                       LineHeight="18"
                       VerticalAlignment="Center"/>

            <!-- Rich track info (Show Current Track) — hidden until populated -->
            <StackPanel x:Name="TrackPanel"
                        Grid.Column="2"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        Margin="0,2,0,2">

                <!-- Track name -->
                <TextBlock x:Name="TrackText"
                           Foreground="{StaticResource BrushText}"
                           FontFamily="Segoe UI Variable"
                           FontSize="14"
                           FontWeight="Normal"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,2"/>

                <!-- Artist — bold, accent-tinted -->
                <TextBlock x:Name="ArtistText"
                           Foreground="{StaticResource BrushAccent}"
                           FontFamily="Segoe UI Variable"
                           FontSize="12.5"
                           FontWeight="Bold"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,2"/>

                <!-- Album — smaller, muted -->
                <TextBlock x:Name="AlbumText"
                           Foreground="{StaticResource BrushTextMuted}"
                           FontFamily="Segoe UI Variable"
                           FontSize="11.5"
                           FontStyle="Italic"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
