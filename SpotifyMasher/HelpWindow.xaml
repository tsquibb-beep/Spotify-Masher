<Window x:Class="SpotifyMasher.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help &amp; About — Spotify Masher"
        Width="560" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBg}">

    <Window.Resources>
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,14,0,6" />
        </Style>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="20" />
        </Style>
        <Style x:Key="TblHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="0,4,12,4" />
        </Style>
        <Style x:Key="TblCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="0,5,12,5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="TblCellMuted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="0,5,12,5" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>

        <!-- Custom tab strip -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="0,0,0,1" Padding="8,0,0,0">
                                <TabPanel IsItemsHost="True" Background="Transparent" />
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="{StaticResource FontLexend}" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent" Margin="0,0,0,-1">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushAccent}" />
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource BrushText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- ══════════════════════════════ HELP TAB ══════════════════════════════ -->
            <TabItem Header="Help">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                    <StackPanel Margin="24,14,24,24">

                        <!-- Getting Started -->
                        <TextBlock Style="{StaticResource SectionHead}" Text="Getting Started" />
                        <TextBlock Style="{StaticResource BodyText}">
                            <Run>1. Go to </Run>
                            <Hyperlink NavigateUri="https://developer.spotify.com/dashboard"
                                       RequestNavigate="Link_RequestNavigate">developer.spotify.com/dashboard</Hyperlink>
                            <Run> and create a new app.</Run>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource BodyText}" VerticalAlignment="Center"
                                       Text="2. Add Redirect URI: " />
                            <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource BrushText}"
                                       VerticalAlignment="Center" Text="http://127.0.0.1:5001/callback" />
                            <Button Content="Copy" Click="CopyUri_Click" Style="{StaticResource GhostButton}"
                                    Padding="8,3" FontSize="11" Margin="8,0,0,0" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,6,0,0"
                                   Text="3. Copy the Client ID and paste it into the auth panel, then click Authorise." />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                                   Text="4. Approve once in the browser — Spotify Masher reconnects silently on every future launch." />

                        <!-- Configuring Hotkeys -->
                        <TextBlock Style="{StaticResource SectionHead}" Text="Configuring Hotkeys" />
                        <TextBlock Style="{StaticResource BodyText}">
                            Click <Run FontWeight="SemiBold" Foreground="{StaticResource BrushText}">Hotkeys</Run>, then
                            <Run FontWeight="SemiBold" Foreground="{StaticResource BrushText}">+ Add Hotkey</Run>.
                            Click in the Keybinding cell and press your key combo.
                            Choose an action, enter a parameter if needed, then click
                            <Run FontWeight="SemiBold" Foreground="{StaticResource BrushText}">Save</Run>.
                        </TextBlock>

                        <!-- Action Reference -->
                        <TextBlock Style="{StaticResource SectionHead}" Text="Action Reference" />
                        <Border Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="1" CornerRadius="6" Padding="12,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="125" />
                                    <ColumnDefinition Width="75" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource TblHead}" Text="Action" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource TblHead}" Text="Parameter" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource TblHead}" Text="Description" />
                                <Separator Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                           Background="{StaticResource BrushBorder}" Height="1" Margin="0,0,0,2" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource TblCell}" Text="Play / Pause" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="(none)" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource TblCell}" Text="Toggle playback. Wakes Spotify on this device if idle." />

                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource TblCell}" Text="Change Volume" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="+5 or -10" />
                                <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource TblCell}" Text="Adjust volume by the given percentage." />

                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource TblCell}" Text="Next Track" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="(none)" />
                                <TextBlock Grid.Row="4" Grid.Column="2" Style="{StaticResource TblCell}" Text="Skip to the next track." />

                                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource TblCell}" Text="Previous Track" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="(none)" />
                                <TextBlock Grid.Row="5" Grid.Column="2" Style="{StaticResource TblCell}" Text="Go back to the previous track." />

                                <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource TblCell}" Text="Seek" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="+30 or -10" />
                                <TextBlock Grid.Row="6" Grid.Column="2" Style="{StaticResource TblCell}" Text="Jump forward or back by the given number of seconds." />

                                <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource TblCell}" Text="Add to Liked" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="(none)" />
                                <TextBlock Grid.Row="7" Grid.Column="2" Style="{StaticResource TblCell}" Text="Save the current track to your Liked Songs." />

                                <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource TblCell}" Text="Add to Playlist" />
                                <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="Playlist ID" />
                                <TextBlock Grid.Row="8" Grid.Column="2" Style="{StaticResource TblCell}" Text="Add the current track to a specific playlist." />

                                <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource TblCell}" Text="Show Current Track" />
                                <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="(none)" />
                                <TextBlock Grid.Row="9" Grid.Column="2" Style="{StaticResource TblCell}" Text="Show a toast with the track name, artist, album, and cover art." />
                            </Grid>
                        </Border>

                        <!-- Finding a Playlist ID -->
                        <TextBlock Style="{StaticResource SectionHead}" Text="Finding a Playlist ID" />
                        <TextBlock Style="{StaticResource BodyText}"
                                   Text="Right-click a playlist in Spotify → Share → Copy link to playlist. Paste the full URL — the ?si= suffix is stripped automatically." />
                        <Border Background="{StaticResource BrushSurface}" CornerRadius="4" Padding="10,7" Margin="0,6,0,0">
                            <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource BrushTextMuted}"
                                       TextWrapping="Wrap"
                                       Text="https://open.spotify.com/playlist/37i9dQZF1DX4sWSpwq3LiO?si=abc" />
                        </Border>

                        <!-- Toast Notifications -->
                        <TextBlock Style="{StaticResource SectionHead}" Text="Toast Notifications" />
                        <TextBlock Style="{StaticResource BodyText}"
                                   Text="Each hotkey row has a Show Toast toggle — enable it to see a notification when that action fires. Configure toasts in the Notifications section of the main window." />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,2"
                                   Text="Two position modes:" />
                        <TextBlock Style="{StaticResource BodyText}"
                                   Text="• Corner + offset — pick a screen corner and set how many pixels in from the edge." />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                                   Text="• Freehand — click Drag to set position and drag the preview to wherever you want." />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0"
                                   Text="Per-app overrides let you set a different toast position when a specific app is in focus. Add the process name (e.g. chrome.exe) and use the drag picker to set its position." />

                        <!-- Toast Style &amp; Presets -->
                        <TextBlock Style="{StaticResource SectionHead}" Text="Toast Style" />
                        <TextBlock Style="{StaticResource BodyText}">
                            Open <Run FontWeight="SemiBold" Foreground="{StaticResource BrushText}">Toast Style</Run>,
                            pick a look from the <Run FontWeight="SemiBold" Foreground="{StaticResource BrushText}">Preset</Run>
                            dropdown, then click <Run FontWeight="SemiBold" Foreground="{StaticResource BrushText}">Save Style</Run>.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0">
                            To use your own colours, choose <Run FontWeight="SemiBold" Foreground="{StaticResource BrushText}">Aurora Custom</Run>,
                            then set the four gradient colours and the background colour — click a swatch to open the
                            colour picker, or type a hex code.
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0"
                                   Text="Click Preview Toast to see your choice before saving, or Reset to Defaults to start over." />

                        <!-- Tips -->
                        <TextBlock Style="{StaticResource SectionHead}" Text="Tips" />
                        <TextBlock Style="{StaticResource BodyText}"
                                   Text="• Closing the window hides to the tray — hotkeys keep working." />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                                   Text="• Enable Launch at Startup from the tray menu to start automatically on login." />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                                   Text="• Hotkeys are global — they work even when Spotify is in the background." />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                                   Text="• Ctrl+Shift+` toggles the debug log." />

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════════════════════ ABOUT TAB ══════════════════════════════ -->
            <TabItem Header="About">
                <Grid>
                    <!-- Background watermark logo — adjust these values to taste:
                         Width/Height  = size of the image
                         Canvas.Left   = horizontal offset (-Width/2 centres it)
                         Canvas.Top    = vertical offset (-Height/2 centres it)
                         Opacity       = 0.0 (invisible) to 1.0 (full) -->
                    <Canvas Width="0" Height="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsHitTestVisible="False">
                        <Image Source="/Resources/fuspotify.png"
                               Width="700" Height="700"
                               Opacity="0.40"
                               Canvas.Left="-320" Canvas.Top="-230"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Canvas>

                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#33000000" CornerRadius="10" Padding="32,24">
                        <StackPanel>
                            <TextBlock Text="Spotify Masher" FontSize="26" FontWeight="Bold"
                                       Foreground="{StaticResource BrushAccent}"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="VersionText" Text="v0.0.0"
                                       FontSize="12" Foreground="{StaticResource BrushTextMuted}"
                                       HorizontalAlignment="Center" Margin="0,4,0,24" />
                            <TextBlock FontStyle="Italic" FontSize="13" Foreground="{StaticResource BrushTextMuted}"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                       MaxWidth="380"
                                       Text="Because Spotify keep spotifucking it all up"
                                       Margin="0,0,0,8" />
                            <TextBlock FontSize="13" Foreground="{StaticResource BrushTextMuted}"
                                       HorizontalAlignment="Center"
                                       Text="Built by Tom and Claude"
                                       Margin="0,0,0,28" />
                            <TextBlock HorizontalAlignment="Center" FontSize="12">
                                <Hyperlink NavigateUri="https://github.com/tsquibb-beep/Spotify-Masher"
                                           RequestNavigate="Link_RequestNavigate">
                                    github.com/tsquibb-beep/Spotify-Masher
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Close button -->
        <Button Grid.Row="1" Content="Close" Style="{StaticResource GhostButton}"
                HorizontalAlignment="Right" Margin="0,8,24,12"
                Click="Close_Click" />
    </Grid>
</Window>
