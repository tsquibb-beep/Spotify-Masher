<Window x:Class="SpotifyMasher.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help &amp; About — Spotify Masher"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBg}">

    <Window.Resources>
        <!-- Section heading -->
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,14,0,6" />
        </Style>

        <!-- Body text -->
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="20" />
        </Style>

        <!-- Table header cell -->
        <Style x:Key="TblHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="0,4,12,4" />
        </Style>

        <!-- Table body cell -->
        <Style x:Key="TblCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="0,5,12,5" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- Muted table body cell (for parameter column) -->
        <Style x:Key="TblCellMuted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="0,5,12,5" />
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <StackPanel Margin="24,20,24,24">

            <!-- ── Title ── -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Image Source="/Resources/fuspotify256.png" Width="36" Height="36"
                       Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Spotify Masher" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource BrushAccent}" />
                    <TextBlock x:Name="VersionText" Text="v0.1.0"
                               FontSize="11" Foreground="{StaticResource BrushTextMuted}" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>

            <Separator Background="{StaticResource BrushBorder}" Height="1" Margin="0,10,0,0" />

            <!-- ── Getting Started ── -->
            <TextBlock Style="{StaticResource SectionHead}" Text="Getting Started" />
            <TextBlock Style="{StaticResource BodyText}">
                <Run>1. Go to </Run><Hyperlink NavigateUri="https://developer.spotify.com/dashboard"
                    RequestNavigate="Link_RequestNavigate">developer.spotify.com/dashboard</Hyperlink>
                <Run> and create a new app.</Run>
            </TextBlock>
            <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                       Text="2. Add the Redirect URI: http://127.0.0.1:5001/callback" />
            <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                       Text="3. Copy the Client ID and paste it into the auth panel, then click Authorise." />
            <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                       Text="4. After approving once in the browser, Spotify Masher reconnects silently on every future launch — no browser needed again." />

            <!-- ── Configuring Hotkeys ── -->
            <TextBlock Style="{StaticResource SectionHead}" Text="Configuring Hotkeys" />
            <TextBlock Style="{StaticResource BodyText}">
                Click <Run FontWeight="SemiBold" Foreground="{StaticResource BrushText}">Edit Hotkeys</Run>, then
                <Run FontWeight="SemiBold" Foreground="{StaticResource BrushText}">+ Add Hotkey</Run> to add a row.
                Click in the Keybinding cell and press your desired key combination.
                Choose an action from the dropdown, enter a parameter if needed, then click
                <Run FontWeight="SemiBold" Foreground="{StaticResource BrushText}">Save</Run>.
            </TextBlock>

            <!-- ── Action Reference ── -->
            <TextBlock Style="{StaticResource SectionHead}" Text="Action Reference" />

            <Border Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Headers -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource TblHead}" Text="Action" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource TblHead}" Text="Parameter" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource TblHead}" Text="Description" />

                    <Separator Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                               Background="{StaticResource BrushBorder}" Height="1" Margin="0,0,0,2" />

                    <!-- Play / Pause -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource TblCell}" Text="Play / Pause" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="(none)" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource TblCell}" Text="Toggle playback on the active device." />

                    <!-- Change Volume -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource TblCell}" Text="Change Volume" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="+5 or -10" />
                    <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource TblCell}" Text="Adjust volume by the given percentage (0–100)." />

                    <!-- Next / Previous -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource TblCell}" Text="Next / Prev Track" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="(none)" />
                    <TextBlock Grid.Row="4" Grid.Column="2" Style="{StaticResource TblCell}" Text="Skip to next or previous track." />

                    <!-- Seek -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource TblCell}" Text="Seek" />
                    <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="+30 or -10" />
                    <TextBlock Grid.Row="5" Grid.Column="2" Style="{StaticResource TblCell}" Text="Jump forward or back by the given number of seconds." />

                    <!-- Add to Liked -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource TblCell}" Text="Add to Liked" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="(none)" />
                    <TextBlock Grid.Row="6" Grid.Column="2" Style="{StaticResource TblCell}" Text="Save the currently playing track to your Liked Songs." />

                    <!-- Add to Playlist -->
                    <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource TblCell}" Text="Add to Playlist" />
                    <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource TblCellMuted}" Text="Playlist ID" />
                    <TextBlock Grid.Row="7" Grid.Column="2" Style="{StaticResource TblCell}" Text="Add the currently playing track to a specific playlist." />
                </Grid>
            </Border>

            <!-- ── Finding a Playlist ID ── -->
            <TextBlock Style="{StaticResource SectionHead}" Text="Finding a Playlist ID" />
            <TextBlock Style="{StaticResource BodyText}"
                       Text="Open Spotify, right-click the playlist and choose Share → Copy link to playlist. You'll get a URL like:" />
            <Border Background="{StaticResource BrushSurface}" CornerRadius="4" Padding="10,7" Margin="0,6,0,6">
                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{StaticResource BrushTextMuted}"
                           TextWrapping="Wrap"
                           Text="https://open.spotify.com/playlist/37i9dQZF1DX4sWSpwq3LiO?si=abc123" />
            </Border>
            <TextBlock Style="{StaticResource BodyText}">
                Paste the full URL (or just the part after <Run FontFamily="Consolas">playlist/</Run>
                — Spotify Masher strips the <Run FontFamily="Consolas">?si=</Run> suffix automatically).
            </TextBlock>

            <!-- ── Tips ── -->
            <TextBlock Style="{StaticResource SectionHead}" Text="Tips" />
            <TextBlock Style="{StaticResource BodyText}"
                       Text="• The app hides to the tray when you close the window — it keeps listening for hotkeys." />
            <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                       Text="• Press Ctrl+Shift+` (backtick) to toggle the debug log." />
            <TextBlock Style="{StaticResource BodyText}" Margin="0,4,0,0"
                       Text="• Hotkeys work system-wide, even when Spotify is in the background." />

            <Separator Background="{StaticResource BrushBorder}" Height="1" Margin="0,16,0,12" />

            <!-- ── About ── -->
            <TextBlock Text="About" Style="{StaticResource SectionHead}" Margin="0,0,0,6" />
            <TextBlock Style="{StaticResource BodyText}"
                       Text="Spotify Masher is a lightweight open-source utility for Windows. Source code is available on GitHub." />
            <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,0">
                <Hyperlink NavigateUri="https://github.com/tsquibb-beep/Spotify-Masher"
                           RequestNavigate="Link_RequestNavigate">
                    github.com/tsquibb-beep/Spotify-Masher
                </Hyperlink>
            </TextBlock>

            <!-- Close button -->
            <Button Content="Close" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" Margin="0,20,0,0"
                    Click="Close_Click" />

        </StackPanel>
    </ScrollViewer>
</Window>
