<Window x:Class="SpotifyMasher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SpotifyMasher.Controls"
        xmlns:local="clr-namespace:SpotifyMasher"
        Title="Spotify Masher"
        Width="680" Height="640"
        MinWidth="560" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BrushBg}">

    <Window.Resources>
        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#885555" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FF6666" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header -->
            <RowDefinition Height="Auto" />   <!-- Auth panel -->
            <RowDefinition Height="*" />      <!-- Hotkey table -->
            <RowDefinition Height="Auto" />   <!-- Footer buttons -->
            <RowDefinition Height="140" />    <!-- Debug log -->
        </Grid.RowDefinitions>

        <!-- ══ Header ══ -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Spotify Masher" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource BrushAccent}" />
                <TextBlock Text="Global hotkeys for Spotify" FontSize="12"
                           Foreground="{StaticResource BrushTextMuted}" Margin="0,2,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="StatusDot" Width="10" Height="10"
                         Fill="#555566" Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusLabel" Text="Not connected"
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ══ Auth Panel ══ -->
        <Border Grid.Row="1"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,14" Margin="0,0,0,16">

            <Grid>
            <!-- Connected: compact single row -->
            <StackPanel x:Name="AuthConnected" Orientation="Horizontal" Visibility="Collapsed">
                <Ellipse Width="10" Height="10" Fill="{StaticResource BrushAccent}"
                         VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock Text="Spotify is connected" FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,20,0" />
                <Button Content="Disconnect"
                        Style="{StaticResource PrimaryButton}"
                        Click="DisconnectButton_Click" />
            </StackPanel>

            <!-- Disconnected: full form -->
            <Grid x:Name="AuthDisconnected">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Connect your Spotify account"
                           FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />

                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ClientIdBox" Grid.Column="0" Margin="0,0,8,0" />

                    <Button x:Name="AuthButton" Grid.Column="1"
                            Content="Authorise with Spotify"
                            Style="{StaticResource PrimaryButton}"
                            Click="AuthButton_Click" />
                </Grid>

                <TextBlock x:Name="AuthStatusText" Grid.Row="2"
                           Text="Enter your Spotify Client ID from developer.spotify.com/dashboard"
                           Foreground="{StaticResource BrushTextMuted}"
                           FontSize="11" TextWrapping="Wrap" />
            </Grid>
            </Grid>
        </Border>

        <!-- ══ Hotkey table ══ -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Hotkeys" FontWeight="SemiBold"
                       FontSize="14" Margin="0,0,0,8" />

            <!-- Margin gives breathing room so rounded corners are visible on all sides -->
            <Border Grid.Row="1"
                    BorderBrush="{StaticResource BrushBorder}"
                    Background="{StaticResource BrushSurface}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Margin="2">
                <DataGrid x:Name="HotkeyGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Keybinding" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:HotkeyBox BindingTarget="{Binding}"
                                                        Margin="4,3"
                                                        Background="{StaticResource BrushSurface2}"
                                                        Foreground="{StaticResource BrushText}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Action" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{x:Static local:MainWindow.AvailableActions}"
                                              SelectedItem="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="4,3" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Parameter" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Parameter, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="4,3" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="" Width="36">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Style="{StaticResource DeleteButton}"
                                            Tag="{Binding}"
                                            Click="DeleteRow_Click" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ══ Footer ══ -->
        <Grid Grid.Row="3" Margin="0,12,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="+ Add Hotkey"
                    Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Left"
                    Click="AddHotkey_Click" />

            <Button x:Name="SaveButton" Grid.Column="1" Content="Save"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click" />

            <Button Grid.Column="3" Content="Minimise to Tray"
                    Style="{StaticResource GhostButton}"
                    Click="MinimiseToTray_Click" />
        </Grid>

        <!-- ══ Debug Log ══ -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Debug Log" FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Clear" Click="ClearLog_Click"
                        Style="{StaticResource GhostButton}" Padding="8,2" FontSize="11" />
            </Grid>

            <TextBox x:Name="LogBox" Grid.Row="1"
                     IsReadOnly="True"
                     FontFamily="Consolas" FontSize="10"
                     Background="#0D0D1A"
                     Foreground="#88CC88"
                     BorderBrush="{StaticResource BrushBorder}"
                     BorderThickness="1"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     Padding="6" />
        </Grid>
    </Grid>
</Window>
