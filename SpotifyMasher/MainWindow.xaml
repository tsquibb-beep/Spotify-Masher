<Window x:Class="SpotifyMasher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SpotifyMasher.Controls"
        xmlns:local="clr-namespace:SpotifyMasher"
        Title="Spotify Masher"
        Width="580"
        MinWidth="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{StaticResource BrushBg}">

    <Window.Resources>
        <Style x:Key="DeleteButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#885555" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FF6666" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background watermark logo — adjust these values to taste:
             Width/Height  = size of the image
             Canvas.Left   = horizontal position (negative = bleeds off left edge)
             Canvas.Top    = vertical position (-Height/2 centres it)
             Opacity       = 0.0 (invisible) to 1.0 (full)
             Canvas is zero-size so it never affects window height. -->
        <Canvas Width="0" Height="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                IsHitTestVisible="False">
            <Image Source="/Resources/fuspotify.png"
                   Width="340" Height="340"
                   Opacity="0.15"
                   Canvas.Left="-80" Canvas.Top="-150"
                   RenderOptions.BitmapScalingMode="HighQuality" />
        </Canvas>

        <!-- Main content -->
        <Grid Margin="20,14,20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header -->
            <RowDefinition Height="Auto" />   <!-- Auth form (disconnected only) -->
            <RowDefinition Height="Auto" />   <!-- Hotkey section (collapsible) -->
            <RowDefinition Height="Auto" />   <!-- Notification settings (collapsible) -->
            <RowDefinition Height="Auto" />   <!-- Footer -->
            <RowDefinition Height="Auto" />   <!-- Debug log (Ctrl+Shift+` to toggle) -->
        </Grid.RowDefinitions>

        <!-- ══ Header ══ -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Spotify Masher" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource BrushAccent}" />
                <TextBlock Text="Global hotkeys for Spotify" FontSize="12"
                           Foreground="{StaticResource BrushTextMuted}" Margin="0,3,0,0" />
            </StackPanel>

            <!-- Connected state -->
            <StackPanel x:Name="AuthConnected" Grid.Column="1"
                        Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="Collapsed">
                <Ellipse Width="10" Height="10" Fill="{StaticResource BrushAccent}"
                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="Spotify is connected" FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button Content="Disconnect" Style="{StaticResource PrimaryButton}"
                        Click="DisconnectButton_Click" />
            </StackPanel>

            <!-- Disconnected state -->
            <StackPanel x:Name="AuthDisconnected" Grid.Column="1"
                        Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="#555566"
                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="Not connected" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button Content="Connect" Style="{StaticResource GhostButton}"
                        Click="ConnectButton_Click" />
            </StackPanel>
        </Grid>

        <!-- ══ Auth Form (shown when disconnected) ══ -->
        <Border x:Name="AuthFormSection" Grid.Row="1"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ClientIdBox" Grid.Column="0" Margin="0,0,8,0" />

                    <Button x:Name="AuthButton" Grid.Column="1"
                            Content="Authorise with Spotify"
                            Style="{StaticResource PrimaryButton}"
                            Click="AuthButton_Click" />
                </Grid>

                <TextBlock x:Name="AuthStatusText" Grid.Row="1"
                           Foreground="{StaticResource BrushTextMuted}"
                           FontSize="11" TextWrapping="Wrap">
                    <Run Text="Enter your Spotify Client ID from " /><Hyperlink
                        NavigateUri="https://developer.spotify.com/dashboard"
                        RequestNavigate="DashboardLink_RequestNavigate">developer.spotify.com/dashboard</Hyperlink>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ══ Hotkey section (collapsible) ══ -->
        <!-- The column headers (Keybinding / Action / Parameter) label the content;
             no separate heading needed. Transparent header background prevents corner bleed. -->
        <Grid x:Name="HotkeySection" Grid.Row="2" Margin="0,0,0,10" Visibility="Collapsed">
            <Border BorderBrush="{StaticResource BrushBorder}"
                    Background="{StaticResource BrushSurface}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True"
                    MaxHeight="280"
                    Padding="1"
                    Margin="1">
                <DataGrid x:Name="HotkeyGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Keybinding" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <controls:HotkeyBox BindingTarget="{Binding}"
                                                        Margin="4,3"
                                                        Background="{StaticResource BrushSurface2}"
                                                        Foreground="{StaticResource BrushText}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Action" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{x:Static local:MainWindow.AvailableActions}"
                                              SelectedItem="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                                              Margin="4,3" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Parameter" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Parameter, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="4,3" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Toast" Width="52">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding ShowToast, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="4,3"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="" Width="36">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Style="{StaticResource DeleteButton}"
                                            Tag="{Binding}"
                                            Click="DeleteRow_Click" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ══ Notification Settings (collapsible) ══ -->
        <Border x:Name="NotifSection" Grid.Row="3" Margin="0,0,0,10"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1" CornerRadius="8"
                Visibility="Collapsed">
            <StackPanel Margin="14">

                    <CheckBox x:Name="NotifEnabled" Content="Enable toast notifications"
                              Margin="0,0,0,10"/>

                    <!-- Corner + Offsets -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Position:" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextMuted}" FontSize="12" Margin="0,0,8,0"/>
                        <ComboBox x:Name="NotifCorner" Grid.Column="1"
                                  ItemsSource="{x:Static local:MainWindow.AvailableCorners}"
                                  SelectionChanged="NotifCorner_SelectionChanged"/>
                        <TextBlock Grid.Column="3" Text="X offset:" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextMuted}" FontSize="12" Margin="0,0,6,0"/>
                        <TextBox x:Name="NotifOffsetX" Grid.Column="4" TextAlignment="Right"/>
                        <TextBlock Grid.Column="6" Text="Y offset:" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextMuted}" FontSize="12" Margin="0,0,6,0"/>
                        <TextBox x:Name="NotifOffsetY" Grid.Column="7" TextAlignment="Right"/>
                        <!-- Corner indicator: 2×2 dot grid showing active quadrant -->
                        <Border Grid.Column="9" Width="34" Height="34" VerticalAlignment="Center"
                                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="4">
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="CornerIndTL" Grid.Row="0" Grid.Column="0" Margin="2"/>
                                <Ellipse x:Name="CornerIndTR" Grid.Row="0" Grid.Column="1" Margin="2"/>
                                <Ellipse x:Name="CornerIndBL" Grid.Row="1" Grid.Column="0" Margin="2"/>
                                <Ellipse x:Name="CornerIndBR" Grid.Row="1" Grid.Column="1" Margin="2"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Button Content="Set Position..." Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,10"
                            Click="SetGlobalPosition_Click"/>

                    <!-- Duration + AlwaysOnTop -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Duration (ms):" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextMuted}" FontSize="12" Margin="0,0,8,0"/>
                        <TextBox x:Name="NotifDuration" Grid.Column="1" TextAlignment="Right"/>
                        <CheckBox x:Name="NotifAlwaysOnTop" Grid.Column="2"
                                  Content="Always on top  (borderless windowed games only)"
                                  Margin="16,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                    </Grid>

                    <!-- Per-process overrides -->
                    <TextBlock Text="Per-process overrides" FontSize="12" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource BrushTextMuted}"
                               Margin="0,0,0,6" TextWrapping="Wrap">
                        When this .exe is the foreground window, use the specified position instead.
                    </TextBlock>

                    <Border BorderBrush="{StaticResource BrushBorder}"
                            Background="{StaticResource BrushBg}"
                            BorderThickness="1" CornerRadius="6"
                            ClipToBounds="True" MaxHeight="150" Padding="1" Margin="0,0,0,8">
                        <DataGrid x:Name="ProcessRuleGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Process (.exe)" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="4,3"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Corner" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{x:Static local:MainWindow.AvailableCorners}"
                                                      SelectedItem="{Binding Corner, UpdateSourceTrigger=PropertyChanged}"
                                                      Margin="4,3"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="X" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding OffsetX, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="4,3" TextAlignment="Right"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Y" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding OffsetY, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="4,3" TextAlignment="Right"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="32">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="📍" Style="{StaticResource GhostButton}"
                                                    Tag="{Binding}" Click="SetProcessRulePosition_Click"
                                                    Padding="2,0" FontSize="13"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="36">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" Style="{StaticResource DeleteButton}"
                                                    Tag="{Binding}" Click="DeleteProcessRule_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Button Content="+ Add Rule" Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Left" Click="AddProcessRule_Click"/>
            </StackPanel>
        </Border>

        <!-- ══ Footer ══ -->
        <Grid Grid.Row="4" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <!-- When hotkeys collapsed: Hotkeys -->
                <StackPanel x:Name="HotkeyCollapsedButtons" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="Hotkeys" Style="{StaticResource GhostButton}"
                            Click="EditHotkeys_Click"/>
                </StackPanel>
                <!-- When hotkeys expanded: + Add Hotkey + Save -->
                <StackPanel x:Name="HotkeyExpandedButtons" Orientation="Horizontal"
                            Margin="0,0,8,0" Visibility="Collapsed">
                    <Button Content="+ Add Hotkey" Style="{StaticResource GhostButton}"
                            Click="AddHotkey_Click" Margin="0,0,8,0"/>
                    <Button x:Name="SaveButton" Content="Save Hotkeys" Style="{StaticResource PrimaryButton}"
                            Click="Save_Click"/>
                </StackPanel>
                <!-- When notifications collapsed: Notifications -->
                <StackPanel x:Name="NotifCollapsedButton" Orientation="Horizontal">
                    <Button Content="Notifications" Style="{StaticResource GhostButton}"
                            Click="ToggleNotifications_Click"/>
                </StackPanel>
                <!-- When notifications expanded: Save Notifications -->
                <StackPanel x:Name="NotifExpandedButton" Orientation="Horizontal"
                            Visibility="Collapsed">
                    <Button Content="Save Notifications" Style="{StaticResource PrimaryButton}"
                            Click="SaveNotifications_Click"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="2" Content="?" Width="30" Height="30" Padding="0"
                    Style="{StaticResource GhostButton}"
                    Click="Help_Click" ToolTip="Help &amp; About" />
        </Grid>

        <!-- ══ Debug Log (Ctrl+Shift+` to toggle, or via tray menu) ══ -->
        <Grid x:Name="DebugSection" Grid.Row="5" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="130" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Debug Log" FontWeight="SemiBold" FontSize="11"
                           Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Clear" Click="ClearLog_Click"
                        Style="{StaticResource GhostButton}" Padding="8,2" FontSize="11" />
            </Grid>

            <TextBox x:Name="LogBox" Grid.Row="1"
                     IsReadOnly="True"
                     FontFamily="Consolas" FontSize="10"
                     Background="#0D0D1A"
                     Foreground="#88CC88"
                     BorderBrush="{StaticResource BrushBorder}"
                     BorderThickness="1"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     Padding="6" />
        </Grid>
        </Grid>
    </Grid>
</Window>
