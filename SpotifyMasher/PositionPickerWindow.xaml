<Window x:Class="SpotifyMasher.PositionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource BrushSurface}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14,10"
            MinWidth="240"
            MaxWidth="300"
            Cursor="SizeAll"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="12" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto" MinWidth="100"/>
            </Grid.ColumnDefinitions>

            <!-- Sample toast text — single line, matches real toast font/size -->
            <TextBlock Grid.Column="0"
                       Text="🔊 Volume: 80%"
                       Foreground="{StaticResource BrushText}"
                       FontFamily="{StaticResource FontLexend}"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0" Height="18"/>

            <!-- ✓ / ✕ confirm/cancel buttons — use TextBlocks so Foreground renders correctly -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Height="24" VerticalAlignment="Center" Width="100" HorizontalAlignment="Center">
                <TextBlock Text="✓"
                           Foreground="{StaticResource BrushAccent}"
                           FontSize="25" FontWeight="Bold"
                           Padding="6,2" Cursor="Hand"
                           RenderTransformOrigin="0.5,0.5"
                           MouseLeftButtonDown="DoneText_MouseDown" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30,0,0,0">
                    <TextBlock.RenderTransform>
                        <ScaleTransform/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                        From="1.0" To="1.15" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                        From="1.0" To="1.15" Duration="0:0:0.5">
                                        <DoubleAnimation.EasingFunction>
                                            <SineEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                <TextBlock Text="✕"
                           Foreground="#FF5555"
                           FontSize="25"
                           Padding="4,2" Cursor="Hand"
                           MouseLeftButtonDown="CancelText_MouseDown" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Anchor indicator: right-angle triangle at the top-left corner
                 The right-angle vertex = the window's (Left, Top) = the saved position.
                 Canvas is zero-size so it doesn't affect layout; negative offsets
                 place the triangle at the visible corner of the Border. -->
            <Canvas Width="0" Height="0"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsHitTestVisible="False">
                <Polygon Canvas.Left="-70" Canvas.Top="-23"
                         Points="0,0 9,0 0,9"
                         Fill="{StaticResource BrushAccent}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            </Canvas>
        </Grid>
    </Border>
</Window>
