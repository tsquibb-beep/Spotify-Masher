<Window x:Class="SpotifyMasher.PositionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource BrushSurface}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14,10"
            MinWidth="240"
            MaxWidth="300"
            Cursor="SizeAll"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="12" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Sample toast text — single line, matches real toast font/size -->
            <TextBlock Grid.Column="0"
                       Text="🔊 Volume: 80%"
                       Foreground="{StaticResource BrushText}"
                       FontFamily="Segoe UI Variable"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <!-- ✓ / ✕ confirm/cancel buttons — use TextBlocks so Foreground renders correctly -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="✓"
                           Foreground="{StaticResource BrushAccent}"
                           FontSize="20" FontWeight="Bold"
                           Padding="6,2" Cursor="Hand"
                           MouseLeftButtonDown="DoneText_MouseDown"/>
                <TextBlock Text="✕"
                           Foreground="#FF5555"
                           FontSize="18"
                           Padding="4,2" Cursor="Hand"
                           MouseLeftButtonDown="CancelText_MouseDown"/>
            </StackPanel>

            <!-- Anchor indicator: right-angle triangle at the top-left corner
                 The right-angle vertex = the window's (Left, Top) = the saved position.
                 Canvas is zero-size so it doesn't affect layout; negative offsets
                 place the triangle at the visible corner of the Border. -->
            <Canvas Width="0" Height="0"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    IsHitTestVisible="False">
                <Polygon Canvas.Left="-6" Canvas.Top="-2"
                         Points="0,0 20,0 0,20"
                         Fill="{StaticResource BrushAccent}"/>
            </Canvas>
        </Grid>
    </Border>
</Window>
