<Window x:Class="SpotifyMasher.PositionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        Width="280">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource BrushSurface}"
            BorderBrush="{StaticResource BrushAccent}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.55" BlurRadius="14" ShadowDepth="3"/>
        </Border.Effect>
        <StackPanel>

            <!-- Drag strip -->
            <Border x:Name="DragStrip"
                    Background="{StaticResource BrushSurface2}"
                    CornerRadius="8,8,0,0"
                    Padding="12,8"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="DragStrip_MouseLeftButtonDown">
                <TextBlock Text="Drag to position, then click Done"
                           FontSize="11" Foreground="{StaticResource BrushTextMuted}"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Sample toast body -->
            <StackPanel Margin="14,10,14,4">
                <TextBlock Text="❤️ Liked"
                           Foreground="{StaticResource BrushText}"
                           FontFamily="Segoe UI Variable" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="Song Name – Artist"
                           Foreground="{StaticResource BrushTextMuted}"
                           FontFamily="Segoe UI Variable" FontSize="12"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Done / Cancel -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="14,8,14,12">
                <Button Content="Cancel" Style="{StaticResource GhostButton}"
                        Padding="12,5" Margin="0,0,8,0"
                        Click="CancelButton_Click"/>
                <Button Content="Done" Style="{StaticResource PrimaryButton}"
                        Padding="16,5"
                        Click="DoneButton_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
